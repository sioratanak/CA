{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": "./worker/index.ts",
  "name": "ca",
  "compatibility_date": "2026-06-26",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  }
}
